# Confluence Server connection
CONFLUENCE_BASE_URL=https://jira.dclouds.ru/confluence
CONFLUENCE_USERNAME=your-username
CONFLUENCE_PASSWORD=your-password
CONFLUENCE_VERIFY_SSL=true

# FastAPI server settings
# Use 127.0.0.1 (not "localhost") to avoid IPv6/resolver surprises.
# In Docker, docker-compose overrides HOST to 0.0.0.0 automatically.
HOST=127.0.0.1
PORT=8765
LOG_LEVEL=INFO

# Attachment safety limits — reject payloads larger than this many bytes.
# Default 25 MiB; raise if you really need to push bigger files through.
CONFLUENCE_MAX_UPLOAD_BYTES=26214400
CONFLUENCE_MAX_DOWNLOAD_BYTES=26214400

# Sandbox directory for the download-to-file tool. The caller's file_path is
# resolved under this directory; paths that escape are rejected.
CONFLUENCE_DOWNLOAD_DIR=./downloads